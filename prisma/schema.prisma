// TNY Catálogo — Prisma schema.
// Identifiers in English; tables/columns mapped to snake_case (plural tables).
// Datasource: SQLite in dev (PostgreSQL via Docker is planned for later).
// NOTE: SQLite has no native Prisma enum. `Order.status` and `Order.payment_method`
// are plain Strings here; their closed value sets are enforced by Zod at the app layer
// (status: new|fulfilled|ignored — payment_method: to_be_defined|boleto|credit_card|cash|pix|bank_transfer).

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id                Int      @id @default(autoincrement())
  sku               String   @unique
  name              String
  description       String
  price             Float // Base full price
  promotional_price Float? // If set, the product is on sale (overrides Variant.price)
  active            Boolean  @default(true) // Soft delete: DELETE via API sets active=false
  created_at        DateTime @default(now())

  categories ProductCategory[]
  variants   Variant[]
  images     Image[]

  @@index([name])
  @@map("products")
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  products ProductCategory[]

  @@map("categories")
}

// Explicit N:N join table between Product and Category.
model ProductCategory {
  product_id  Int
  category_id Int

  product  Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([product_id, category_id])
  @@map("product_categories")
}

model Variant {
  id          Int    @id @default(autoincrement())
  product_id  Int
  variant_sku String @unique
  color       String
  size        String
  quantity    Int // Stock for this variation
  price       Float? // Own price; if null, inherits from Product (unless product is on sale)

  product     Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  images      Image[]
  order_items OrderItem[]

  @@map("variants")
}

model Image {
  id         Int     @id @default(autoincrement())
  product_id Int
  variant_id Int? // Null = general product image; set = specific to a variant
  url        String
  alt_text   String?
  position   Int     @default(0)

  product Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)

  @@map("images")
}

model Lead {
  id                Int      @id @default(autoincrement())
  name              String
  email             String   @unique // Unique enables the upsert flow
  phone             String
  marketing_consent Boolean  @default(true)
  consent_date      DateTime @default(now())
  created_at        DateTime @default(now())

  @@map("leads")
}

model Order {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String
  email          String?
  payment_method String   @default("to_be_defined") // enum-like (validated by Zod)
  message        String?
  notes          String?
  total          Float
  status         String   @default("new") // enum-like: new | fulfilled | ignored
  created_at     DateTime @default(now())

  items OrderItem[]

  @@index([status])
  @@map("orders")
}

model OrderItem {
  id           Int    @id @default(autoincrement())
  order_id     Int
  variant_id   Int
  product_name String // Frozen at purchase time
  color        String // Frozen at purchase time
  size         String // Frozen at purchase time
  quantity     Int
  unit_price   Float // Resolved (inheritance + promotion) and frozen

  order   Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variant_id], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Admin {
  id                    Int       @id @default(autoincrement())
  name                  String
  email                 String    @unique
  password_hash         String
  active                Boolean   @default(true)
  failed_login_attempts Int       @default(0)
  locked_until          DateTime?
  created_at            DateTime  @default(now())

  @@map("admins")
}
