# Database (SQLite in dev — PostgreSQL via Docker is planned for later).
# SQLite path is relative to the project root.
DATABASE_URL="file:./prisma/dev.db"

# HTTP server
PORT=3000
NODE_ENV=dev

# Auth — secret used to sign JWTs (use a long random value in production)
JWT_SECRET="change-me"

# CORS — allowed origin(s). Use "*" in dev, a concrete origin in production.
CORS_ORIGIN="*"
