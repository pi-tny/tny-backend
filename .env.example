# Database: sqlite (dev) or postgres (prod). DATABASE_PROVIDER picks the driver.
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./prisma/dev.db"

# Docker Postgres:
# DATABASE_PROVIDER="postgres"
# DATABASE_URL="postgresql://user:pass@localhost:5433/db"

# Supabase (requires two URLs):
# DATABASE_PROVIDER="postgres"
# DATABASE_URL="postgresql://user@region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://user@region.supabase.com:5432/postgres"
# DIRECT_URL is only used by prisma migrate / seed — never by the runtime server.

# HTTP server
PORT=3000
NODE_ENV=dev

# Auth — secret used to sign JWTs (use a long random value in production)
JWT_SECRET="change-me"

# CORS — allowed origin(s). Use "*" in dev, a concrete origin in production.
CORS_ORIGIN="*"
